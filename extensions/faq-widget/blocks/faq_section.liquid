{{ 'faq-widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'faq-widget.js' | asset_url }}" defer="defer"></script>

<div class="faqify-widget-container" 
     data-shop="{{ shop.permanent_domain }}" 
     data-category="{{ section.settings.category_filter }}"
     data-style="{{ section.settings.display_style }}"
     data-search="{{ section.settings.show_search }}"
     data-votes="{{ section.settings.show_helpful_votes }}"
     data-primary-color="{{ section.settings.primary_color }}"
     data-secondary-color="{{ section.settings.secondary_color }}"
     data-background-color="{{ section.settings.background_color }}"
     data-text-color="{{ section.settings.text_color }}"
     data-card-background="{{ section.settings.card_background }}"
     data-border-color="{{ section.settings.border_color }}"
     data-font-family="{{ section.settings.font_family }}"
     data-heading-font-size="{{ section.settings.heading_font_size }}"
     data-body-font-size="{{ section.settings.body_font_size }}"
     data-question-font-weight="{{ section.settings.question_font_weight }}"
     data-border-radius="{{ section.settings.border_radius }}"
     data-card-padding="{{ section.settings.card_padding }}"
     data-item-spacing="{{ section.settings.item_spacing }}"
     data-container-max-width="{{ section.settings.container_max_width }}"
     data-card-shadow="{{ section.settings.card_shadow }}"
     data-card-border-width="{{ section.settings.card_border_width }}"
     data-card-hover-effect="{{ section.settings.card_hover_effect }}"
     data-icon-style="{{ section.settings.icon_style }}"
     data-icon-color="{{ section.settings.icon_color }}">
  
  {% if section.settings.title != blank %}
    <h2 class="faqify-title">{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.settings.show_search %}
    <div class="faqify-search">
      <input type="text" placeholder="Search questions..." class="faqify-search-input" />
    </div>
  {% endif %}

  <div class="faqify-content-area">
    <!-- FAQs will be dynamically rendered here by JS -->
    <div class="faqify-loading">Loading FAQs...</div>
  </div>

  <script type="application/json" class="faqify-block-data">
    [
      {% for block in section.blocks %}
        {
          "id": "{{ block.id }}",
          "question": {{ block.settings.question | json }},
          "answer": {{ block.settings.answer | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>

  {% if section.settings.show_branding %}
    <div class="faqify-branding">
      <small>Powered by <a href="#" target="_blank">FAQify Pro</a></small>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "FAQify Pro — FAQ Section",
  "target": "section",
  "settings": [
    { "type": "paragraph", "content": "Template selection and colors will override App Dashboard if used. Leave blank to use App Dashboard designs." },
    { "type": "text", "id": "title", "label": "Section Title", "default": "Frequently Asked Questions" },
    { "type": "select", "id": "display_style", "label": "Display Style", "options": [
        {"value": "app", "label": "App Dashboard Setting"},
        {"value": "classic", "label": "Classic Accordion"},
        {"value": "card", "label": "Modern Card"},
        {"value": "dark", "label": "Dark Mode Premium"},
        {"value": "split", "label": "Split Layout"},
        {"value": "grid", "label": "Grid Cards"},
        {"value": "masonry", "label": "Masonry Layout"}
    ], "default": "app" },
    { "type": "select", "id": "category_filter", "label": "Show Category", "options": [{"value": "all", "label": "All Categories"}], "default": "all" },
    { "type": "checkbox", "id": "show_search", "label": "Show Search Bar", "default": true },
    { "type": "checkbox", "id": "show_helpful_votes", "label": "Show Helpful/Not Helpful Buttons", "default": true },
    { "type": "header", "content": "Colors (Leave blank to use App settings)" },
    { "type": "color", "id": "primary_color", "label": "Primary Color" },
    { "type": "color", "id": "secondary_color", "label": "Secondary Color" },
    { "type": "color", "id": "background_color", "label": "Background Color" },
    { "type": "color", "id": "text_color", "label": "Text Color" },
    { "type": "color", "id": "card_background", "label": "Card Background" },
    { "type": "color", "id": "border_color", "label": "Border Color" },
    { "type": "color", "id": "icon_color", "label": "Icon Color" },
    { "type": "header", "content": "Typography" },
    { "type": "select", "id": "font_family", "label": "Font Family", "options": [
      {"value": "", "label": "Use App Dashboard Default"},
      {"value": "Inter", "label": "Inter"},
      {"value": "Roboto", "label": "Roboto"},
      {"value": "Outfit", "label": "Outfit"},
      {"value": "Poppins", "label": "Poppins"}
    ], "default": "" },
    { "type": "text", "id": "heading_font_size", "label": "Heading Font Size (px)" },
    { "type": "text", "id": "body_font_size", "label": "Body Font Size (px)" },
    { "type": "select", "id": "question_font_weight", "label": "Question Font Weight", "options": [
      {"value": "", "label": "Use App Dashboard Default"},
      {"value": "400", "label": "Normal"},
      {"value": "500", "label": "Medium"},
      {"value": "600", "label": "Semibold"},
      {"value": "700", "label": "Bold"}
    ], "default": "" },
    { "type": "header", "content": "Layout & Sizing" },
    { "type": "text", "id": "border_radius", "label": "Border Radius (px)" },
    { "type": "text", "id": "card_padding", "label": "Card Padding (px)" },
    { "type": "text", "id": "item_spacing", "label": "Item Spacing (px)" },
    { "type": "text", "id": "container_max_width", "label": "Container Max Width (px)" },
    { "type": "header", "content": "Card Styles" },
    { "type": "select", "id": "card_shadow", "label": "Card Shadow", "options": [
      {"value": "", "label": "Use App Dashboard Default"},
      {"value": "none", "label": "None"},
      {"value": "sm", "label": "Small"},
      {"value": "md", "label": "Medium"},
      {"value": "lg", "label": "Large"}
    ], "default": "" },
    { "type": "text", "id": "card_border_width", "label": "Card Border Width (px)" },
    { "type": "select", "id": "card_hover_effect", "label": "Card Hover Effect", "options": [
      {"value": "", "label": "Use App Dashboard Default"},
      {"value": "none", "label": "None"},
      {"value": "lift", "label": "Lift Up"},
      {"value": "glow", "label": "Glow"},
      {"value": "border", "label": "Highlight Border"}
    ], "default": "" },
    { "type": "select", "id": "icon_style", "label": "Icon Style", "options": [
      {"value": "", "label": "Use App Dashboard Default"},
      {"value": "chevron", "label": "Chevron"},
      {"value": "plus", "label": "Plus / Minus"},
      {"value": "arrow", "label": "Arrow"}
    ], "default": "" },
    { "type": "checkbox", "id": "show_branding", "label": "Show Powered by FAQify", "default": true }
  ]
}
{% endschema %}
